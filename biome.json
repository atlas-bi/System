{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"files": {
		"includes": [
			"**",
			"!!**/node_modules",
			"!!**/build",
			"!!**/public/build",
			"!!**/test/saml-idp",
			"!!**/data.ms",
			"!!**/postgres-data"
		]
	},
	"formatter": {
		"enabled": true
	},
	"assist": {
		"enabled": false
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false
		}
	}
}

{
	"extends": [
		"config:recommended",
		"group:allNonMajor",
		":separateMultipleMajorReleases",
		":ignoreUnstable",
		":enableVulnerabilityAlertsWithLabel(security)",
		":rebaseStalePrs",
		":npm",
		"security:minimumReleaseAgeNpm"
	],
	"baseBranchPatterns": ["dev"],
	"bumpVersion": "patch",
	"commitMessagePrefix": "fix(deps)",
	"labels": ["maintenance", "renovate"],
	"packageRules": [
		{
			"matchPackageNames": ["remix-auth", "remix-auth-form", "remix-auth-saml"],
			"enabled": false,
			"description": "Hold remix-auth on the v3 API until route loaders are migrated off authenticator.isAuthenticated."
		},
		{
			"matchUpdateTypes": ["pin", "digest", "minor", "patch"],
			"automerge": true
		},
		{
			"matchDepTypes": ["devDependencies"],
			"automerge": true
		},
		{
			"extends": ["packages:linters"],
			"groupName": "linters",
			"automerge": true
		},
		{
			"extends": ["packages:test"],
			"groupName": "test packages",
			"automerge": true
		}
	],
	"schedule": ["before 10pm on Sunday"],
	"timezone": "America/Chicago"
}
